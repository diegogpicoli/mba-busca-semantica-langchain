# Providers: openai or gemini
EMBEDDING_PROVIDER=openai
LLM_PROVIDER=openai

# API keys
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Model names (required by the challenge)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-5-nano
GOOGLE_EMBEDDING_MODEL=models/embedding-001
GOOGLE_CHAT_MODEL=gemini-2.5-flash-lite

# PGVector
PGVECTOR_CONNECTION=postgresql+psycopg://langchain:langchain@localhost:6024/langchain
PGVECTOR_COLLECTION=pdf_chunks
PGVECTOR_USE_JSONB=true

# Ingestion
PDF_PATH=document.pdf
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Search
TOP_K=10
